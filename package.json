{
  "name": "lobi-app-back",
  "version": "0.0.1",
  "description": "TFG back-end",
  "repository": "git@github.com:carlosp1604/lobi-app-back.git",
  "author": "Carlos Ponton",
  "private": true,
  "license": "MIT",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "yarn type-check && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest",
    "test-unit": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --selectProjects unit",
    "test-integration": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --selectProjects integration",
    "test-integration-db": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --selectProjects integration-db",
    "test-e2e": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --selectProjects e2e",
    "test:watch": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --watch",
    "test:cov": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test jest --coverage",
    "test:debug": "cross-env DOTENV_CONFIG_QUIET=true NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prepare": "husky",
    "husky:init": "husky init",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "migration:create": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:create src/db/migrations/InitSchema",
    "migration:run": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:run -d src/db/config/data-source.ts",
    "migration:revert": "ts-node --project tsconfig.typeorm.json ./node_modules/typeorm/cli.js migration:revert -d src/db/config/data-source.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.2.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/node": "^10.11.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.2",
    "ipaddr.js": "^2.2.0",
    "jsonwebtoken": "^9.0.2",
    "nestjs-cls": "^6.2.0",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "postmark": "^4.0.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.26",
    "zod": "^4.1.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@fastify/compress": "^8.1.0",
    "@fastify/helmet": "^13.0.1",
    "@jest/globals": "^30.1.2",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^11.5.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/postmark": "^2.0.3",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "fast-check": "^4.3.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "jest": "^30.0.0",
    "jest-environment-node": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.1.6",
    "pino-pretty": "^13.1.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.5.1",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "maxWorkers": 1,
    "coverageProvider": "babel",
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!dist/**",
      "!coverage/**",
      "!src/main.ts",
      "!src/app.module.ts",
      "!src/db/**",
      "!src/test/**",
      "!src/modules/**/Infrastructure/**/**.module.ts",
      "!src/modules/**/Infrastructure/**/**.tokens.ts",
      "!src/modules/**/Infrastructure/**/**.entity.ts",
      "!src/modules/**/Infrastructure/**/**.pipe.ts",
      "!src/modules/**/Infrastructure/**/**.filter.ts",
      "!src/modules/Shared/Infrastructure/EnvHelper.ts",
      "!src/modules/Shared/Infrastructure/FastifyApplication.ts",
      "!src/modules/Shared/Infrastructure/GlobalValidationPipe.ts"
    ],
    "coverageDirectory": "../coverage",
    "projects": [
      {
        "displayName": "unit",
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "rootDir": ".",
        "testMatch": [
          "<rootDir>/src/**/*.spec.ts"
        ],
        "testPathIgnorePatterns": [
          "\\.integration\\.spec\\.ts$",
          "\\.integration\\.db\\.spec\\.ts$",
          "\\.e2e\\.spec\\.ts$",
          "<rootDir>/test/"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^~/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "integration",
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "rootDir": ".",
        "testMatch": [
          "<rootDir>/**/*\\.integration\\.spec\\.ts"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node",
        "moduleNameMapper": {
          "^~/(.*)$": "<rootDir>/$1"
        }
      },
      {
        "displayName": "integration-db",
        "testTimeout": 60000,
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "rootDir": ".",
        "testMatch": [
          "<rootDir>/**/*\\.integration\\.db\\.spec\\.ts"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "<rootDir>/src/test/config/integration/testEnvironment.js",
        "moduleNameMapper": {
          "^~/(.*)$": "<rootDir>/$1"
        },
        "setupFilesAfterEnv": [
          "<rootDir>/src/test/config/integration/jest.setup.js"
        ],
        "globalSetup": "<rootDir>/src/test/config/integration/global.setup.js",
        "globalTeardown": "<rootDir>/src/test/config/integration/global.teardown.js"
      },
      {
        "displayName": "e2e",
        "testTimeout": 60000,
        "moduleFileExtensions": [
          "js",
          "json",
          "ts"
        ],
        "rootDir": ".",
        "testMatch": [
          "<rootDir>/**/*\\.e2e\\.spec\\.ts"
        ],
        "transform": {
          "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "<rootDir>/src/test/config/integration/testEnvironment.js",
        "moduleNameMapper": {
          "^~/(.*)$": "<rootDir>/$1"
        },
        "setupFilesAfterEnv": [
          "<rootDir>/src/test/config/integration/jest.setup.js"
        ],
        "globalSetup": "<rootDir>/src/test/config/integration/global.setup.js",
        "globalTeardown": "<rootDir>/src/test/config/integration/global.teardown.js"
      }
    ]
  }
}
